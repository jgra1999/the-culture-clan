---
import { ViewTransitions } from 'astro:transitions';

import Footer from '../components/layaout/Footer.astro';
import Header from '../components/layaout/Header.astro';
interface Props {
	title: string | undefined;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<ViewTransitions />

		<!-- SEO -->
		<meta name="description" content="Marca de Ropa. ofrecemos una amplia variedad de diseños y estilos para hombres y mujeres." >
		<meta name="robots" content="index, follow" >		
		<link rel="canonical" href="https://thecultureclan.com" >

		<!-- Open Graph -->
		<meta property="og:type" content="website">
		<meta property="og:image" content="https://res.cloudinary.com/df8nnzf8t/image/upload/v1702386655/logo_mywb2f.jpg" >
		<meta property="og:url" content="https://thecultureclan.com/">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		
		<!-- favicon -->
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">

		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@100;300;400;500;700;900&display=swap" rel="stylesheet">
		<title>The Culture Clan - {title}</title>

		<!-- Google tag (gtag.js) -->
		<script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-9XN6FNH6J4"></script>
		<script type="text/partytown">
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-9XN6FNH6J4');
		</script>
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.0/flowbite.min.js"></script>
		
	</body>
</html>

<style is:global>
	html {
		height: 100%;
	}
	
	body {
		@apply 
		bg-[#141414] 
		text-[#F6F6F6];

		font-family: 'Roboto', sans-serif;
	}

    .social-icon{
		@apply stroke-[1.5] opacity-50 hover:opacity-100 w-9 h-9
	}

	::-webkit-scrollbar {
		@apply w-2 bg-black;
	}

	::-webkit-scrollbar-thumb {
		@apply bg-zinc-800 rounded;
	}

	.item-name{
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 1;

		}
</style> 
