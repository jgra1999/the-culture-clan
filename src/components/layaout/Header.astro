---
import LoginIcon from '../icons/LoginIcon.astro';
import Logo from '../icons/Logo.astro'
import TCCIcon from '../icons/TCCIcon.astro';
import Wishlist from '../shop/Wishlist';
import SideMenu from './SideMenu';
---

<header class='absolute top-0 w-full'>
    {/* mobile navbar */}
    <div class='p-4 flex justify-between items-center lg:hidden'>
        <SideMenu client:idle transition:persist/>
        <a href="/">
            <TCCIcon />
        </a>
        <Wishlist client:visible transition:persist/>
    </div>

    <!-- Desktop navbar -->
    <div class='hidden lg:flex flex-col relative'>
        <!-- top bar -->
        <div class='bg-black opacity-30 py-5'>
        </div>
        <div class="flex gap-x-8 justify-end items-end absolute top-2.5 right-8">
            <a href="/sign-in" class='flex items-center gap-x-1 opacity-75 hover:opacity-100'>
                <LoginIcon styles="w-5 h-5" />
                <span class="text-sm" >Iniciar Sesión</span>
            </a>
            <Wishlist client:idle transition:persist/>
        </div>
        <!-- bottom bar -->
        <nav class='bg-transparent flex justify-between items-center px-5'>
            <a href="/">
                <Logo />
            </a >

            <ul class='flex gap-x-[70px] font-medium uppercase'>
                <li>
                    <a href="/" class="opacity-70 hover:opacity-100">Home</a>
                </li>
                <li>
                    <a href="/tienda" class="opacity-75 hover:opacity-100">Tienda</a>
                </li>
                <li>
                    <a href="/" class="opacity-70 hover:opacity-100">Sobre Nosotros</a>
                </li>
                <li>
                    <a href="/contacto" class="opacity-70 hover:opacity-100">Contacto</a>
                </li>
                
            </ul>

            <form>
                <input
                    type='text'
                    placeholder='Buscar'
                    class='bg-transparent border border-white py-2 px-3 text-xs w-72 opacity-50 focus:opacity-100 outline-none rounded-lg'
                />
            </form>
        </nav>
    </div>
</header>