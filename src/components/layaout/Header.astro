---
import Logo from '../icons/Logo.astro'
import ShoppingBagIcon from '../icons/ShoppingBagIcon.astro'
import TCCIcon from '../icons/TCCIcon.astro';
import SideMenu from './SideMenu.astro';
---

<header class='absolute top-0 w-full'>
    {/* mobile navbar */}
    <div class='p-4 flex justify-between items-center lg:hidden'>
        <SideMenu />
        <a href="/">
            <TCCIcon />
        </a>
        <ShoppingBagIcon />
    </div>

    <!-- Desktop navbar -->
    <div class='hidden lg:flex flex-col px-5 p-3'>
        <!-- top bar -->
        <div class='bg-transparent flex gap-x-8 justify-end items-end'>
            <a href="/sign-in" class='text-xs opacity-50 hover:opacity-100 text-white'>Iniciar Sesión</a>
            <ShoppingBagIcon />
        </div>
        <!-- bottom bar -->
        <nav class='bg-transparent flex justify-between items-center'>
            <a href="/">
                <Logo />
            </a >

            <ul class='flex gap-x-[70px] font-medium uppercase'>
                <li>
                    <a href="/" class="opacity-70 hover:opacity-100">Home</a>
                </li>
                <li>
                    <a href="/tienda" class="opacity-75 hover:opacity-100">Tienda</a>
                </li>
                <li>
                    <a href="/" class="opacity-70 hover:opacity-100">Sobre Nosotros</a>
                </li>
                <li>
                    <a href="/contacto" class="opacity-70 hover:opacity-100">Contacto</a>
                </li>
                
            </ul>

            <form>
                <input
                    type='text'
                    placeholder='Buscar'
                    class='bg-transparent border border-white py-2 px-3 text-xs w-72 opacity-50 focus:opacity-100 outline-none rounded-lg'
                />
            </form>
        </nav>
    </div>
</header>