---

<AdminLayout title="Dashboard" >
    <div>
        <p class="font-medium">Ultimos 7 dias</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10" >
        <StatsCard name="Fondos" growth={20.18} stats={`$${245988.54}`} tableUrl="./fondo" />
        <StatsCard name="Ventas" growth={4.18} stats={`$${988.33}`} tableUrl="./ventas" />
        <StatsCard name="Gastos" growth={-4.18} stats={`$${87.74}`} tableUrl="./gastos" />
        <StatsCard name="Usuarios" stats={`${127}`} tableUrl="./usuarios" />
        <StatsCard name="Productos" stats={`${24}`} tableUrl="./productos" />
    </div>
</AdminLayout>