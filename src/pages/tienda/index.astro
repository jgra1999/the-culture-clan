---
import Layout from "../../layouts/Layout.astro"

import FiltersBar from "../../components/FiltersBar.astro";
import ItemsList from '../../components/shop/ItemsList.astro'

---

<Layout title="Tienda">
    <main class="pt-28 lg:pt-52 px-14">
        <div class="flex flex-col gap-y-10 lg:gap-y-32 items-center divide-y-2 divide-mediumGray">
            <h2 class="text-2xl lg:text-5xl font-bold uppercase tracking-wider text-center" >
                Todos los Productos
            </h2>
            <FiltersBar />
        </div>
        
        <ItemsList />
    </main>
</Layout>